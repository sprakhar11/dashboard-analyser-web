# Backend API base URL
# This is the URL of the backend server that the app communicates with.
# Required for the ping health check and all API calls.
VITE_BASE_URL=http://localhost:3000
# Authentication API base URL
# This is the URL of the authentication server that handles user registration,
# login, logout, and profile retrieval.
# Required for all auth-related API calls.
VITE_AUTH_BASE_URL=http://localhost:8080
